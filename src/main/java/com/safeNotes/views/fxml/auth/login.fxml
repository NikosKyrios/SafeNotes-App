<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.safeNotes.controllers.auth.LoginController"
            stylesheets="@../../css/auth-styles.css"
            prefWidth="400" prefHeight="500">
    
    <center>
        <VBox alignment="CENTER" spacing="20">
            <!-- App Logo/Title -->
            <VBox alignment="CENTER" spacing="10">
                <Label text="🔐 SafeNotes" styleClass="app-title"/>
                <Label text="Secure Note Taking" styleClass="app-subtitle"/>
            </VBox>
            
            <!-- Login Form -->
            <VBox alignment="CENTER_LEFT" spacing="15" styleClass="form-container">
                <Label text="Login" styleClass="form-title"/>
                
                <!-- Username -->
                <VBox spacing="5">
                    <Label text="Username" styleClass="input-label"/>
                    <TextField fx:id="usernameField" promptText="Enter username"
                             styleClass="text-field"/>
                </VBox>
                
                <!-- Password -->
                <VBox spacing="5">
                    <Label text="Password" styleClass="input-label"/>
                    <PasswordField fx:id="passwordField" promptText="Enter password"
                                 styleClass="password-field"/>
                    
                    <!-- Keystroke Timing Indicator -->
                    <HBox spacing="10" visible="false" fx:id="keystrokeIndicator">
                        <ProgressIndicator fx:id="typingProgress" progress="0" prefWidth="20" prefHeight="20"/>
                        <Label text="Analyzing typing pattern..." styleClass="hint-text"/>
                    </HBox>
                </VBox>
                
                <!-- Remember Me & Forgot Password -->
                <HBox spacing="20">
                    <CheckBox fx:id="rememberMeCheck" text="Remember me"/>
                    <Button text="Forgot Password?" styleClass="link-button"
                            onAction="#onForgotPassword"/>
                </HBox>
                
                <!-- Login Button -->
                <Button text="Login" onAction="#onLogin" styleClass="primary-button"
                        defaultButton="true"/>
                
                <!-- Register Link -->
                <HBox alignment="CENTER" spacing="5">
                    <Label text="Don't have an account?"/>
                    <Button text="Register" styleClass="link-button"
                            onAction="#onRegister"/>
                </HBox>
                
                <!-- Security Status -->
                <VBox fx:id="securityStatusBox" visible="false" spacing="5"
                      styleClass="security-status">
                    <Label fx:id="securityStatusLabel" text=""/>
                    <ProgressBar fx:id="securityProgress" progress="0" prefWidth="300"/>
                </VBox>
            </VBox>
        </VBox>
    </center>
    
    <!-- Footer with Security Info -->
    <bottom>
        <HBox alignment="CENTER" styleClass="footer">
            <Label text="🔒 All data encrypted locally" styleClass="footer-text"/>
        </HBox>
    </bottom>
</BorderPane>